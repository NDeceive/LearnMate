PORT=5800
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=请填写数据库密码
DB_NAME=edusmart

# Authentication. Use a long random value outside development.
JWT_SECRET=请填写至少32位随机字符串
JWT_EXPIRES_IN=8h

# Optional development seed credentials. Passwords are bcrypt-hashed before storage.
DEMO_PASSWORD=请设置演示账号密码
SEED_DEMO_DATA=false

# Assessment PDF generation. Windows normally discovers these automatically.
REPORT_BROWSER_PATH=
REPORT_FONT_PATH=

SPARK_API_URL=https://spark-api-open.xf-yun.com/v1/chat/completions
SPARK_MODEL=lite
SPARK_API_KEY=请填写你的讯飞星火 APIPassword
SPARK_APP_ID=
SPARK_API_SECRET=
SPARK_TIMEOUT_MS=30000

# Disabled by default. When enabled, PlannerAgent output is still validated against the database catalog.
PATH_PLANNER_AI_ENABLED=false
MULTIMODAL_RESOURCE_AI_ENABLED=false
MULTIMODAL_REVIEW_AI_ENABLED=false
