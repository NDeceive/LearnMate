# Runtime
NODE_ENV=development
HOST=0.0.0.0
PORT=5800
TZ=Asia/Shanghai

# MySQL (DB_PASSWORD is required; production rejects missing/example values.)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change-me-database-password
DB_NAME=edusmart
DB_CONNECT_TIMEOUT_MS=5000
DB_INIT_MAX_ATTEMPTS=15
DB_INIT_RETRY_MS=2000

# Authentication (production requires at least 32 non-placeholder characters.)
JWT_SECRET=change-me-use-a-random-secret-at-least-32-characters
JWT_EXPIRES_IN=8h

# Comma-separated browser origins. Production never accepts a wildcard.
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:8081

# Persistent storage. Relative paths are resolved from the backend working directory.
RESOURCE_STORAGE_DIR=./storage/resources
REPORT_STORAGE_DIR=./storage/reports

# Startup automation is opt-in and idempotent. It never resets demo data.
KNOWLEDGE_IMPORT_ON_START=false
SEED_DEMO_DATA=false
DEMO_PASSWORD=change-me-demo-password
# One-time legacy-volume migration only. Leave empty during normal seed/startup.
DEMO_ADOPT_LEGACY_CONFIRM=

# Explicit global AI switch. The application has deterministic behavior when false.
AI_ENABLED=false
PATH_PLANNER_AI_ENABLED=false
MULTIMODAL_RESOURCE_AI_ENABLED=false
MULTIMODAL_REVIEW_AI_ENABLED=false

# Optional iFlytek Spark configuration; required only when AI_ENABLED=true.
SPARK_API_URL=https://spark-api-open.xf-yun.com/v1/chat/completions
SPARK_MODEL=lite
SPARK_API_KEY=
SPARK_APP_ID=
SPARK_API_SECRET=
SPARK_TIMEOUT_MS=30000

# PDF generation. Windows can normally auto-discover Edge and CJK fonts.
# The backend Docker image sets these to Chromium and Noto Sans CJK.
REPORT_BROWSER_PATH=
REPORT_FONT_PATH=
