# Copy this file to .env before running Docker Compose. Never commit .env.
# Required in production: use long, unique random values and do not reuse them.
MYSQL_ROOT_PASSWORD=
DB_PASSWORD=
JWT_SECRET=

# Application and database
NODE_ENV=production
DB_NAME=learnmate
DB_USER=learnmate
DB_CONNECT_TIMEOUT_MS=5000
JWT_EXPIRES_IN=8h
TZ=Asia/Shanghai
DB_INIT_MAX_ATTEMPTS=30
DB_INIT_RETRY_MS=2000

# Compose keeps these container-internal contracts fixed:
# HOST=0.0.0.0
# PORT=5800
# DB_HOST=mysql
# DB_PORT=3306
# RESOURCE_STORAGE_DIR=/app/storage/resources
# REPORT_STORAGE_DIR=/app/storage/reports

# Host bindings. Loopback is the safe single-machine default.
BIND_ADDRESS=127.0.0.1
BACKEND_PORT=5800
STUDENT_PORT=8080
TEACHER_PORT=8081
MYSQL_DEBUG_PORT=3306
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8081,http://127.0.0.1:8081

# First-start automation. Both operations are idempotent and opt-in.
KNOWLEDGE_IMPORT_ON_START=true
SEED_DEMO_DATA=false
DEMO_PASSWORD=
# One-time legacy-volume migration only. Leave empty during normal operation.
DEMO_ADOPT_LEGACY_CONFIRM=

# AI is optional. Keep disabled for an offline, deterministic competition demo.
AI_ENABLED=false
PATH_PLANNER_AI_ENABLED=false
MULTIMODAL_RESOURCE_AI_ENABLED=false
MULTIMODAL_REVIEW_AI_ENABLED=false
SPARK_API_URL=https://spark-api-open.xf-yun.com/v1/chat/completions
SPARK_MODEL=lite
SPARK_API_KEY=
SPARK_APP_ID=
SPARK_API_SECRET=
SPARK_TIMEOUT_MS=30000

# The backend image provides Chromium and a Chinese font at these paths.
REPORT_BROWSER_PATH=/usr/bin/chromium
REPORT_FONT_PATH=/usr/share/fonts/opentype/noto/NotoSansCJK-Regular.ttc

# Local image label; it is not pushed by Compose or CI.
LEARNMATE_IMAGE_TAG=local
